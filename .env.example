# Node-RED connection URL (required)
# NODE_RED_URL=http://localhost:1880

# Node-RED API token (optional, for standalone Node-RED)
# NODE_RED_TOKEN=your-api-token

# MCP runtime transport (optional)
# MCP_TRANSPORT=stdio

# HTTP service settings for streamable-http mode
# MCP_HOST=0.0.0.0
# MCP_PORT=3000
# MCP_PATH=/mcp

# For Home Assistant add-on, embed credentials in URL:
# NODE_RED_URL=http://username:password@homeassistant.local:1880
